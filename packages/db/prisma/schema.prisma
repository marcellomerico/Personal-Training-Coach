// Prisma-Schema – Phase 1 (Grundgerüst & Auth).
// Weitere Entities (activities, daily_health_metrics, ...) folgen in Phase 2+.
// Siehe docs/data-model.md für das vollständige konzeptionelle Modell.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum UserStatus {
  active
  disabled
}

enum Provider {
  strava
  garmin_official
  garmin_unofficial
}

enum ProviderAccountStatus {
  connected
  expired
  revoked
  error
}

enum SyncJobType {
  backfill
  incremental
  token_refresh
  webhook
}

enum SyncJobStatus {
  queued
  running
  success
  failed
}

// Trainings-/Erholungsempfehlung des Readiness-Engines (Phase 5).
// Bewusst getrennt vom Coach-Typ DailyDecision ('moderate'); hier 'normal'.
enum ReadinessDecision {
  rest
  easy
  normal
  hard
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  passwordHash   String?    @map("password_hash")
  role           UserRole   @default(user)
  status         UserStatus @default(active)
  telegramUserId BigInt?    @unique @map("telegram_user_id")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  profile          UserProfile?
  providerAccounts ProviderAccount[]
  syncJobs         SyncJob[]
  sessions         Session[]
  telegramLinkTokens TelegramLinkToken[]
  rawImports       RawImport[]
  activities       Activity[]
  dailyHealthMetrics DailyHealthMetric[]
  sleepRecords     SleepRecord[]
  readinessMetrics ReadinessMetric[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  // SHA-256-Hash des Session-Tokens (Klartext-Token lebt nur im httpOnly-Cookie).
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  userAgent String?  @map("user_agent")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model TelegramLinkToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  // SHA-256-Hash des Link-Tokens (Einmal-Token, kurzlebig).
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("telegram_link_tokens")
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  displayName        String?  @map("display_name")
  birthDate          DateTime? @map("birth_date")
  sex                String?
  heightCm           Int?     @map("height_cm")
  weightKg           Float?   @map("weight_kg")
  maxHr              Int?     @map("max_hr")
  restingHrBaseline  Int?     @map("resting_hr_baseline")
  hrvBaseline        Float?   @map("hrv_baseline")
  timezone           String   @default("Europe/Berlin")
  locale             String   @default("de")
  goals              Json?
  preferences        Json?
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model ProviderAccount {
  id             String                @id @default(cuid())
  userId         String                @map("user_id")
  provider       Provider
  externalUserId String?               @map("external_user_id")
  // Verschlüsselt at rest via @ptc/config (ptc:v1), nie Klartext speichern/loggen.
  accessToken    String?               @map("access_token")
  refreshToken   String?               @map("refresh_token")
  tokenExpiresAt DateTime?             @map("token_expires_at")
  scopes         String?
  status         ProviderAccountStatus @default(connected)
  authMode       String?               @map("auth_mode")
  // Verschlüsseltes JSON via @ptc/config (z. B. Garmin-Session-Tokens des inoffiziellen Connectors).
  secrets        String?
  connectedAt    DateTime              @default(now()) @map("connected_at")
  lastSyncAt     DateTime?             @map("last_sync_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncJobs SyncJob[]

  @@unique([userId, provider])
  @@index([userId])
  @@map("provider_accounts")
}

model SyncJob {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  providerAccountId String?        @map("provider_account_id")
  type              SyncJobType
  status            SyncJobStatus  @default(queued)
  rangeFrom         DateTime?      @map("range_from")
  rangeTo           DateTime?      @map("range_to")
  startedAt         DateTime?      @map("started_at")
  finishedAt        DateTime?      @map("finished_at")
  error             String?
  stats             Json?
  attempt           Int            @default(0)
  nextRetryAt       DateTime?      @map("next_retry_at")
  createdAt         DateTime       @default(now()) @map("created_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerAccount ProviderAccount? @relation(fields: [providerAccountId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status, nextRetryAt])
  @@map("sync_jobs")
}

// --- Phase 2: Datenimport (Garmin primär) -------------------------------

// Rohdaten-Staging: unveränderte Connector-Antworten für Audit/Reprocessing.
model RawImport {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  providerAccountId String?   @map("provider_account_id")
  source            Provider
  entityType        String    @map("entity_type") // activity | health | sleep
  sourceExternalId  String?   @map("source_external_id")
  payload           Json
  fetchedAt         DateTime  @default(now()) @map("fetched_at")
  processedAt       DateTime? @map("processed_at")
  processingError   String?   @map("processing_error")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, entityType])
  @@index([providerAccountId])
  @@map("raw_imports")
}

// Normalisierte Trainingseinheit (provider-unabhängiges Schema).
model Activity {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  providerAccountId String?   @map("provider_account_id")
  source            Provider
  sourceExternalId  String    @map("source_external_id")
  type              String
  startTime         DateTime  @map("start_time")
  timezone          String?
  durationSec       Int       @map("duration_sec")
  distanceM         Float?    @map("distance_m")
  elevationGainM    Float?    @map("elevation_gain_m")
  avgHr             Int?      @map("avg_hr")
  maxHr             Int?      @map("max_hr")
  avgPowerW         Int?      @map("avg_power_w")
  calories          Int?
  perceivedExertion Int?      @map("perceived_exertion")
  trainingLoad      Float?    @map("training_load")
  rawImportId       String?   @map("raw_import_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, sourceExternalId])
  @@index([userId, startTime])
  @@index([providerAccountId])
  @@map("activities")
}

// Tagesaggregierte Gesundheitswerte (HRV, Ruhepuls, Schritte, ...).
model DailyHealthMetric {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  providerAccountId String?  @map("provider_account_id")
  source            Provider
  date              DateTime @db.Date
  restingHr         Int?     @map("resting_hr")
  hrv               Float?
  steps             Int?
  bodyBattery       Int?     @map("body_battery")
  stressAvg         Int?     @map("stress_avg")
  weightKg          Float?   @map("weight_kg")
  // Provider-Spezialwerte ohne eigene Spalte (z. B. Spo2) als JSON.
  extra             Json?
  rawImportId       String?  @map("raw_import_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, source])
  @@index([userId, date])
  @@map("daily_health_metrics")
}

// Schlafdaten je Nacht.
model SleepRecord {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  providerAccountId String?   @map("provider_account_id")
  source            Provider
  date              DateTime  @db.Date
  sleepStart        DateTime? @map("sleep_start")
  sleepEnd          DateTime? @map("sleep_end")
  totalSleepSec     Int?      @map("total_sleep_sec")
  deepSec           Int?      @map("deep_sec")
  lightSec          Int?      @map("light_sec")
  remSec            Int?      @map("rem_sec")
  awakeSec          Int?      @map("awake_sec")
  sleepScore        Int?      @map("sleep_score")
  rawImportId       String?   @map("raw_import_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, source])
  @@index([userId, date])
  @@map("sleep_records")
}

// --- Phase 5: Readiness / Coach-MVP -------------------------------------

// Deterministische Tagesbewertung aus Health-/Schlaf-/Aktivitätsdaten.
// REGELBASIERT (kein LLM); `rationale` hält Inputs + Regel-Beiträge für
// Nachvollziehbarkeit. Hinweis: KEIN medizinischer Rat (v0-Heuristik).
model ReadinessMetric {
  id             String            @id @default(cuid())
  userId         String            @map("user_id")
  date           DateTime          @db.Date
  // 0–100; höher = erholter/belastbarer.
  readinessScore Int               @map("readiness_score")
  // Verhältnisse zur Baseline (z. B. 0.85 = 15 % unter Baseline); null wenn Datum fehlt.
  hrvVsBaseline  Float?            @map("hrv_vs_baseline")
  rhrVsBaseline  Float?            @map("rhr_vs_baseline")
  // 0–1: Schlaf-Güte (aus Sleep-Score bzw. Dauer abgeleitet).
  sleepFactor    Float?            @map("sleep_factor")
  // 0–1: Belastungssignal des Vortages (0 = keine, 1 = harte Einheit).
  loadSignal     Float?            @map("load_signal")
  decision       ReadinessDecision
  rationale      Json
  computedAt     DateTime          @default(now()) @map("computed_at")
  engineVersion  String            @map("engine_version")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("readiness_metrics")
}
