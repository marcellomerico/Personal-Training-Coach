{
  "name": "personal-training-coach",
  "version": "0.0.0",
  "private": true,
  "description": "Persönliches KI-Coach-System für Sport & Gesundheit (Monorepo)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:all": "bash scripts/dev-all.sh",
    "dev:api": "turbo run dev --filter=@ptc/api",
    "dev:bot": "turbo run dev --filter=@ptc/bot",
    "dev:worker": "turbo run dev --filter=@ptc/worker",
    "dev:web": "turbo run dev --filter=@ptc/web",
    "db:generate": "pnpm --filter @ptc/db generate",
    "db:migrate": "pnpm --filter @ptc/db migrate",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
