# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird NICHT committet (siehe .gitignore).

# --- Allgemein ---
NODE_ENV=development

# --- Datenbank (PostgreSQL) ---
# Lokal z. B. via Docker oder lokalem Postgres.
DATABASE_URL=postgresql://ptc:ptc@localhost:5432/ptc?schema=public

# --- API ---
API_PORT=3001
# Schlüssel zur Verschlüsselung sensibler Felder (Tokens) at rest.
# Erzeugen: openssl rand -base64 32
ENCRYPTION_KEY=

# --- Auth / Sessions ---
SESSION_SECRET=

# --- Telegram-Bot ---
TELEGRAM_BOT_TOKEN=

# --- LLM (Claude / Anthropic) ---
# LLM ist optional/abschaltbar.
ANTHROPIC_API_KEY=
LLM_ENABLED=false

# --- Connectors ---
# Strava (sekundär)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Garmin (primär, inoffizieller Connector – Python-Service)
# GARMIN_MODE: official | unofficial | off
GARMIN_MODE=unofficial
GARMIN_CONNECTOR_URL=http://localhost:8000
