# Kopiere diese Datei nach .env und fülle die Werte aus.
# .env wird NICHT committet (siehe .gitignore).

# --- Allgemein ---
NODE_ENV=development
# Strukturierte Logs (pino): fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- Datenbank (PostgreSQL) ---
# Lokal z. B. via Docker oder lokalem Postgres.
DATABASE_URL=postgresql://ptc:ptc@localhost:5432/ptc?schema=public

# --- API ---
API_PORT=3001
# Basis-URL der API (z. B. für den Bot, der die API aufruft).
API_BASE_URL=http://localhost:3001
# Erlaubte CORS-Origins (kommasepariert), z. B. die Web-App im Dev.
WEB_ORIGIN=http://localhost:3000

# --- Web-App (@ptc/web) ---
# Basis-URL der API aus Sicht des Browsers. Default passt für lokale Dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# --- Secret-Verschluesselung ---
# Schlüssel zur Verschlüsselung sensibler Felder (Tokens) at rest.
# Muss mindestens 32 Zeichen lang sein und in Prod stabil bleiben, sonst
# koennen bereits gespeicherte Provider-Secrets nicht mehr entschluesselt werden.
# Erzeugen: openssl rand -base64 32
ENCRYPTION_KEY=

# Interner Shared-Secret für Service-zu-Service-Calls (Bot -> API).
# Wenn leer, ist der interne Endpunkt in der lokalen Dev ungeschützt.
# Erzeugen: openssl rand -base64 32
INTERNAL_API_KEY=

# --- Auth / Sessions ---
SESSION_SECRET=
# Name des Session-Cookies.
SESSION_COOKIE_NAME=ptc_session
# Session-Lebensdauer in Tagen.
SESSION_TTL_DAYS=30

# --- Telegram-Bot ---
TELEGRAM_BOT_TOKEN=
# Bot-Username (ohne @) für Deep-Links: https://t.me/<username>?start=<token>
TELEGRAM_BOT_USERNAME=

# --- LLM (Erklärungsschicht) ---
# Optional/abschaltbar. Das LLM erklärt nur die deterministische Empfehlung
# (explanationText); es entscheidet nichts.
LLM_ENABLED=false
# Anbieter: anthropic (kostenpflichtig) | gemini (Free-Tier verfügbar).
LLM_PROVIDER=anthropic

# Anthropic (Claude) – kostenpflichtig.
ANTHROPIC_API_KEY=
# Modell für den Anthropic-Pfad (z. B. claude-haiku-4-5 für günstiger).
LLM_MODEL=claude-opus-4-8

# Google Gemini – kostenloses Kontingent (https://aistudio.google.com/apikey).
# ACHTUNG: Cloud-Dienst – Gesundheitsdaten verlassen dein Gerät.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Connectors ---
# Strava (sekundär)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Garmin (primär, inoffizieller Connector – Python-Service)
# GARMIN_MODE: official | unofficial | off
GARMIN_MODE=unofficial
GARMIN_CONNECTOR_URL=http://localhost:8000
